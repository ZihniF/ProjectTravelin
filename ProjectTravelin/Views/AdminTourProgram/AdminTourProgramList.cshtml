@model List<ResultTourProgramDto>

@{
    ViewData["Title"] = "Tur Programları";
    Layout = "~/Views/Shared/_TourLayout.cshtml";

    var totalProgramCount = Model?.Count ?? 0;
    var totalTourCount = Model?.Select(x => x.TourId).Distinct().Count() ?? 0;

    var tourLookup = ViewBag.Tours as Dictionary<string, string> ?? new Dictionary<string, string>();
}

@section Styles {
    <style>
        /* ── PAGE HEADER ─────────────────────────────── */
        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 1.6rem;
            font-weight: 800;
            color: #1a202c;
            letter-spacing: -.03em;
            line-height: 1;
        }

        .breadcrumb {
            margin: 0;
            padding: 0;
            background: none;
        }

        .breadcrumb-item {
            font-size: .8rem;
        }

            .breadcrumb-item a {
                color: #2563eb;
                text-decoration: none;
            }

            .breadcrumb-item.active {
                color: #718096;
            }

        /* ── SECTION CARD ────────────────────────────── */
        .form-section {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
            margin-bottom: 1.5rem;
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid #f0f4f8;
            background: #fafbfc;
        }

        .section-header-left {
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .section-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: grid;
            place-items: center;
            font-size: .95rem;
            flex-shrink: 0;
        }

            .section-icon.blue {
                background: #eff6ff;
                color: #2563eb;
            }

            .section-icon.green {
                background: #f0fdf4;
                color: #16a34a;
            }

            .section-icon.amber {
                background: #fffbeb;
                color: #d97706;
            }

        .section-title {
            font-family: var(--font-display);
            font-weight: 700;
            font-size: .92rem;
            color: #1a202c;
        }

        .section-subtitle {
            font-size: .75rem;
            color: #a0aec0;
            margin-top: 1px;
        }

        .section-body {
            padding: 1.5rem;
        }

        /* ── ACTION BUTTONS ──────────────────────────── */
        .btn-submit {
            background: #2563eb;
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: .65rem 1.1rem;
            font-family: var(--font-display);
            font-weight: 700;
            font-size: .85rem;
            cursor: pointer;
            transition: all .15s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .45rem;
            text-decoration: none;
        }

            .btn-submit:hover {
                background: #1d4ed8;
                color: #fff;
                box-shadow: 0 4px 14px rgba(37,99,235,.35);
            }

        .btn-soft {
            background: #fff;
            color: #4a5568;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: .55rem .85rem;
            font-size: .78rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
            text-decoration: none;
        }

            .btn-soft:hover {
                background: #f7fafc;
                border-color: #cbd5e0;
                color: #2d3748;
            }

        .btn-soft-warning {
            color: #d97706;
        }

        .btn-soft-danger {
            color: #e53e3e;
        }

        /* ── STATS ───────────────────────────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 1.1rem 1.25rem;
            box-shadow: 0 2px 12px rgba(0,0,0,.04);
            display: flex;
            align-items: center;
            gap: .9rem;
        }

        .stat-icon {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            font-size: 1.1rem;
        }

            .stat-icon.blue {
                background: #eff6ff;
                color: #2563eb;
            }

            .stat-icon.green {
                background: #f0fdf4;
                color: #16a34a;
            }

            .stat-icon.amber {
                background: #fffbeb;
                color: #d97706;
            }

        .stat-value {
            font-family: var(--font-display);
            font-size: 1.25rem;
            font-weight: 800;
            color: #1a202c;
            line-height: 1;
        }

        .stat-label {
            margin-top: .25rem;
            font-size: .75rem;
            color: #a0aec0;
        }

        /* ── TABLE ───────────────────────────────────── */
        .program-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }

            .program-table thead th {
                background: #f8fafc;
                color: #718096;
                font-size: .72rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .06em;
                padding: .85rem 1rem;
                border-bottom: 1px solid #edf2f7;
                white-space: nowrap;
            }

            .program-table tbody td {
                padding: 1rem;
                border-bottom: 1px solid #edf2f7;
                vertical-align: middle;
                font-size: .84rem;
                color: #4a5568;
            }

            .program-table tbody tr:hover {
                background: #fafbfc;
            }

            .program-table tbody tr:last-child td {
                border-bottom: none;
            }

        .program-thumb {
            width: 92px;
            height: 64px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
        }

        .program-thumb-placeholder {
            width: 92px;
            height: 64px;
            border-radius: 10px;
            border: 1px dashed #cbd5e0;
            background: #f8fafc;
            color: #a0aec0;
            display: grid;
            place-items: center;
            font-size: 1.1rem;
        }

        .tour-title {
            font-weight: 700;
            color: #1a202c;
            font-size: .88rem;
            margin-bottom: .2rem;
        }

        .tour-location {
            color: #a0aec0;
            font-size: .75rem;
            display: flex;
            align-items: center;
            gap: .25rem;
        }

        .day-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            background: #eff6ff;
            color: #2563eb;
            border-radius: 999px;
            padding: .35rem .65rem;
            font-size: .74rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .program-title {
            font-weight: 700;
            color: #2d3748;
            margin-bottom: .25rem;
        }

        .program-desc {
            color: #718096;
            font-size: .78rem;
            line-height: 1.45;
            max-width: 420px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .table-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: .45rem;
        }

        /* ── EMPTY STATE ─────────────────────────────── */
        .empty-state {
            text-align: center;
            padding: 3rem 1.5rem;
        }

        .empty-icon {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            background: #eff6ff;
            color: #2563eb;
            display: grid;
            place-items: center;
            font-size: 1.6rem;
            margin: 0 auto 1rem;
        }

        .empty-title {
            font-family: var(--font-display);
            font-weight: 800;
            color: #1a202c;
            font-size: 1rem;
            margin-bottom: .35rem;
        }

        .empty-subtitle {
            color: #718096;
            font-size: .82rem;
            margin-bottom: 1.2rem;
        }

        /* ── RESPONSIVE ──────────────────────────────── */
        @@media (max-width: 991px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .section-body {
                padding: 1rem;
            }

            .program-table {
                min-width: 900px;
            }

            .table-responsive-custom {
                overflow-x: auto;
            }
        }
    </style>
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <h1 class="page-title">Tur Programları</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Tur Programları</li>
            </ol>
        </nav>
    </div>

    <a asp-controller="AdminTourProgram" asp-action="CreateTourProgram" class="btn-submit">
        <i class="bi bi-plus-circle-fill"></i>
        Yeni Program Ekle
    </a>
</div>

<!-- STATS -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon blue">
            <i class="bi bi-list-check"></i>
        </div>
        <div>
            <div class="stat-value">@totalProgramCount</div>
            <div class="stat-label">Toplam program adımı</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon green">
            <i class="bi bi-map"></i>
        </div>
        <div>
            <div class="stat-value">@totalTourCount</div>
            <div class="stat-label">Programa sahip tur</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon amber">
            <i class="bi bi-calendar3"></i>
        </div>
        <div>
            <div class="stat-value">@(Model != null && Model.Any() ? Model.Max(x => x.DayNumber) : 0)</div>
            <div class="stat-label">En uzun gün planı</div>
        </div>
    </div>
</div>

<!-- LIST SECTION -->
<div class="form-section">
    <div class="section-header">
        <div class="section-header-left">
            <div class="section-icon blue">
                <i class="bi bi-calendar-week"></i>
            </div>
            <div>
                <div class="section-title">Program Listesi</div>
                <div class="section-subtitle">Turlara bağlı günlük program adımlarını yönetin</div>
            </div>
        </div>
    </div>

    <div class="section-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive-custom">
                <table class="program-table">
                    <thead>
                        <tr>
                            <th>Görsel</th>
                            <th>Tur</th>
                            <th>Gün</th>
                            <th>Program İçeriği</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Title" class="program-thumb" />
                                    }
                                    else
                                    {
                                        <div class="program-thumb-placeholder">
                                            <i class="bi bi-image"></i>
                                        </div>
                                    }
                                </td>

                                <td>
                                    @{
                                        var tourText = tourLookup.ContainsKey(item.TourId)
                                            ? tourLookup[item.TourId]
                                            : item.TourId;
                                    }

                                    <div class="tour-title">@tourText</div>
                                    <div class="tour-location">
                                        <i class="bi bi-link-45deg"></i>
                                        Tur ID: @item.TourId
                                    </div>
                                </td>

                                <td>
                                    <span class="day-badge">
                                        <i class="bi bi-sun"></i>
                                        @item.DayNumber. Gün
                                    </span>
                                </td>

                                <td>
                                    <div class="program-title">@item.Title</div>
                                    <div class="program-desc">@item.Description</div>
                                </td>

                                <td>
                                    <div class="table-actions">
                                        <a asp-controller="AdminTourProgram"
                                           asp-action="UpdateTourProgram"
                                           asp-route-id="@item.TourProgramId"
                                           class="btn-soft btn-soft-warning">
                                            <i class="bi bi-pencil-square"></i>
                                            Güncelle
                                        </a>

                                        <a asp-controller="AdminTourProgram"
                                           asp-action="DeleteTourProgram"
                                           asp-route-id="@item.TourProgramId"
                                           class="btn-soft btn-soft-danger js-delete-program">
                                            <i class="bi bi-trash3"></i>
                                            Sil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="bi bi-calendar-plus"></i>
                </div>
                <div class="empty-title">Henüz tur programı eklenmedi</div>
                <div class="empty-subtitle">
                    Tur detay sayfasında günlük program göstermek için ilk program adımını oluşturun.
                </div>
                <a asp-controller="AdminTourProgram" asp-action="CreateTourProgram" class="btn-submit">
                    <i class="bi bi-plus-circle-fill"></i>
                    İlk Programı Ekle
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.js-delete-program').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                const confirmed = confirm('Bu tur programını silmek istediğinize emin misiniz?');

                if (!confirmed) {
                    e.preventDefault();
                }
            });
        });
    </script>
}