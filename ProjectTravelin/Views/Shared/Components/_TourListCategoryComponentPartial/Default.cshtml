@model List<ProjectTravelin.Dtos.CategoryDtos.ResultCategoryDto>

@{
    var selectedCategoryId = Context.Request.Query["categoryId"].ToString();
}

<section class="tour-category-filter-area">
    <div class="container">
        <div class="category-filter-box">
            <div class="category-filter-header">
                <div>
                    <span class="category-small-title">Tur Kategorileri</span>
                    <h3>İlgi Alanına Göre Filtrele</h3>
                </div>

                <p>
                    Kategori seçerek sana uygun turları hızlıca görüntüleyebilirsin.
                </p>
            </div>

            <div class="all-tours-wrapper">
                <a asp-controller="Tour"
                   asp-action="TourList"
                   class="all-tours-btn @(string.IsNullOrEmpty(selectedCategoryId) ? "active" : "")">
                    <i class="fa fa-th-large"></i>
                    <span>Tüm Turlar</span>
                </a>
            </div>

            <div class="category-filter-list">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <a asp-controller="Tour"
                           asp-action="TourList"
                           asp-route-categoryId="@item.CategoryId"
                           class="category-filter-item @(selectedCategoryId == item.CategoryId ? "active" : "")">

                            @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                            {
                                <i class="@item.IconUrl"></i>
                            }
                            else
                            {
                                <i class="fa fa-map-signs"></i>
                            }

                            <span>@item.CategoryName</span>
                        </a>
                    }
                }
            </div>
        </div>
    </div>
</section>

<style>
    .tour-category-filter-area {
        padding: 35px 0 25px;
        background: #fff;
    }

    .category-filter-box {
        background: #ffffff;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        padding: 24px 26px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, .06);
    }

    .category-filter-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 25px;
        margin-bottom: 22px;
    }

    .category-small-title {
        color: #f56960;
        font-size: 15px;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 6px;
    }

    .category-filter-header h3 {
        color: #17233e;
        font-size: 26px;
        font-weight: 800;
        margin: 0;
    }

    .category-filter-header p {
        max-width: 420px;
        color: #777;
        font-size: 14px;
        line-height: 1.6;
        margin: 0;
    }

    .all-tours-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 20px;
    }

    .all-tours-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 13px 26px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        color: #17233e;
        font-size: 15px;
        font-weight: 800;
        text-decoration: none;
        transition: .2s;
        white-space: nowrap;
        box-shadow: 0 8px 20px rgba(15, 23, 42, .06);
    }

        .all-tours-btn i {
            color: #f56960;
            font-size: 16px;
            transition: .2s;
        }

        .all-tours-btn:hover {
            background: #fff7f6;
            border-color: #ffd7d3;
            color: #f56960;
            text-decoration: none;
            transform: translateY(-2px);
        }

        .all-tours-btn.active {
            background: #f56960;
            border-color: #f56960;
            color: #fff;
            box-shadow: 0 10px 22px rgba(245, 105, 96, .28);
        }

            .all-tours-btn.active i {
                color: #fff;
            }

            .all-tours-btn.active:hover {
                background: #e45850;
                border-color: #e45850;
                color: #fff;
            }

    .category-filter-list {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .category-filter-item {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        color: #17233e;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: .2s;
        white-space: nowrap;
    }

        .category-filter-item i {
            color: #f56960;
            font-size: 15px;
            transition: .2s;
        }

        .category-filter-item:hover {
            background: #fff7f6;
            border-color: #ffd7d3;
            color: #f56960;
            text-decoration: none;
            transform: translateY(-2px);
        }

        .category-filter-item.active {
            background: #f56960;
            border-color: #f56960;
            color: #fff;
            box-shadow: 0 8px 18px rgba(245, 105, 96, .25);
        }

            .category-filter-item.active i {
                color: #fff;
            }

            .category-filter-item.active:hover {
                background: #e45850;
                border-color: #e45850;
                color: #fff;
            }

    @@media(max-width: 991px) {
        .category-filter-header {
            display: block;
            text-align: center;
        }

            .category-filter-header p {
                margin: 12px auto 0;
            }

            .category-filter-header h3 {
                font-size: 23px;
            }

        .category-filter-list {
            justify-content: center;
        }
    }

    @@media(max-width: 575px) {
        .category-filter-box {
            padding: 20px 16px;
        }

        .category-filter-list {
            flex-wrap: nowrap;
            overflow-x: auto;
            justify-content: flex-start;
            padding-bottom: 6px;
        }

        .category-filter-item {
            flex-shrink: 0;
        }

        .all-tours-wrapper {
            margin-bottom: 16px;
        }

        .all-tours-btn {
            width: 100%;
            max-width: 260px;
        }
    }
</style>