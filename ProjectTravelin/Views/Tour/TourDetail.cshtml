@model GetTourByIdDto

@{
    Layout = null;
}

<!DOCTYPE html>

@await Component.InvokeAsync("_TourHeadComponentPartial")

@await Component.InvokeAsync("_TourHeaderComponentPartial")

<section class="tour-detail pt-6 pb-6 bg-lgrey">
    <div class="container">

        <div class="row">
            <div class="col-lg-8">
                <div class="tour-detail-main bg-white rounded box-shadow overflow-hidden mb-4">

                    <div class="tour-image">
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="w-100 rounded">
                    </div>

                    <div class="tour-content p-4">
                        <h2 class="mb-2">@Model.Title</h2>

                        <h5 class="theme mb-3">
                            <i class="icon-location-pin"></i>
                            @Model.City, @Model.Country
                        </h5>

                        <p class="mb-4">
                            @Model.Description
                        </p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="border rounded p-3 bg-light">
                                    <strong>Tur Tarihi:</strong>
                                    <p class="mb-0">@Model.TourDate.ToString("dd MMMM yyyy")</p>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="border rounded p-3 bg-light">
                                    <strong>Süre:</strong>
                                    <p class="mb-0">@Model.DayNight</p>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="border rounded p-3 bg-light">
                                    <strong>Kapasite:</strong>
                                    <p class="mb-0">@Model.Capacity kişi</p>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="border rounded p-3 bg-light">
                                    <strong>Lokasyon:</strong>
                                    <p class="mb-0">@Model.Country / @Model.City</p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="tour-description bg-white rounded box-shadow p-4 mb-4">
                    <h3>Tur Hakkında</h3>
                    <p>@Model.Description</p>
                </div>
                @await Component.InvokeAsync("_TourProgramComponentPartial", new { tourId = @Model.TourId })
            </div>

            <div class="col-lg-4">
                <div class="sidebar-sticky">
                    <div class="bg-white rounded box-shadow p-4 mb-4">
                        <h4 class="mb-3">Tur Bilgileri</h4>

                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <strong>Ülke:</strong> @Model.Country
                            </li>
                            <li class="mb-2">
                                <strong>Şehir:</strong> @Model.City
                            </li>
                            <li class="mb-2">
                                <strong>Tarih:</strong> @Model.TourDate.ToString("dd.MM.yyyy")
                            </li>
                            <li class="mb-2">
                                <strong>Süre:</strong> @Model.DayNight
                            </li>
                            <li class="mb-2">
                                <strong>Kapasite:</strong> @Model.Capacity kişi
                            </li>
                        </ul>

                        <a href="/Booking/Index/@Model.TourId" class="nir-btn w-100 text-center mt-3">
                            Rezervasyon Yap
                        </a>
                    </div>

                    <div class="bg-white rounded box-shadow p-4">
                        <h4 class="mb-3">Destek</h4>
                        <p class="mb-0">
                            Bu tur hakkında detaylı bilgi almak veya rezervasyon yapmak için formu doldurabilirsiniz.
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

@await Component.InvokeAsync("_TourFooterComponentPartial")

<div id="back-to-top">
    <a href="#"></a>
</div>

<script src="/travelin/js/jquery-3.5.1.min.js"></script>
<script src="/travelin/js/bootstrap.min.js"></script>
<script src="/travelin/js/fontawesome.min.js"></script>
<script src="/travelin/js/particles.js"></script>
<script src="/travelin/js/particlerun.js"></script>
<script src="/travelin/js/plugin.js"></script>
<script src="/travelin/js/main.js"></script>
<script src="/travelin/js/custom-swiper.js"></script>
<script src="/travelin/js/custom-nav.js"></script>